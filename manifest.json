{
  "manifest_version": 3,
  "name": "MoeKoe 桌面歌词",
  "plugin_id": "moekoe-lyric-desktop",
  "version": "1.0.0",
  "minversion": "1.6.6",
  "moekoe": true,
  "description": "一个MoeKoe Music的第三方桌面歌词程序插件.",
  "author": {
    "name": "MoeKoe Music",
    "url": "https://music.moekoe.cn/"
  },
  "permissions": ["storage"],
  "moekoe_permissions": ["moekoe:nativeHost"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "moekoe_native_hosts": [
    {
      "id": "desktop-lyrics",
      "platforms": {
        "win32": {
          "path": "bin/lyric_exe.exe",
          "args": [
            "--config=eyJhdXRob3IiOiJrdW9kYWZ1IFFROiAxMjEwMDcxMjQsIGdyb3VwOiAyMDc1Mjg0MyIsInN6RGVmVGV4dCI6Ik1vZUtvZSBNdXNpYyDlkKzkvaDmg7PlkKwifQ==",
            "--ws-server=6522"
          ]
        }
      },
      "auto_start": true,
      "bridge": "native-bridge.html"
    }
  ],
  "icons": {
    "128": "icons/icon128.png"
  }
}
